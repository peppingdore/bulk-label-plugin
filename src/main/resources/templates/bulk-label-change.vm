<html>
<head>
    <title>Bulk Label Change</title>
    <meta name="decorator" content="atl.general"/>
</head>
<body>

<div class="wiki-content" style="max-width:760px; margin:32px auto;">

    <div style="margin-bottom:32px;">
        <h1 style="margin-bottom:4px;">Bulk Label Change</h1>
        <p style="color:#6b778c; margin:0;">Rename a label across all pages and blog posts you have permission to edit.</p>
    </div>

    #if($action.hasActionErrors())
    <div class="aui-message aui-message-error" style="margin-bottom:16px;">
        #foreach($error in $action.actionErrors)
            <p>$error</p>
        #end
    </div>
    #end

    #if($action.hasActionMessages())
    <div class="aui-message aui-message-info" style="margin-bottom:16px;">
        #foreach($msg in $action.actionMessages)
            <p>$msg</p>
        #end
    </div>
    #end

    <form id="bulkLabelForm" class="aui" method="POST" action="preview.action">
        #form_xsrfToken()

        ## ── Label inputs side by side ──
        <div style="display:flex; gap:12px; align-items:flex-end; flex-wrap:wrap; margin-bottom:24px;">
            <div style="flex:1; min-width:200px;">
                <label for="sourceLabel" style="display:block; margin-bottom:4px; font-weight:600; font-size:14px;">
                    From label <span class="aui-icon icon-required">(required)</span>
                </label>
                <input class="text" type="text" id="sourceLabel" name="sourceLabel"
                       value="$!{sourceLabel}" placeholder="e.g. old-label"
                       autocomplete="off" required
                       style="width:100%; box-sizing:border-box;"/>
            </div>
            <div style="padding-bottom:8px; color:#6b778c; font-size:22px; flex-shrink:0;">&rarr;</div>
            <div style="flex:1; min-width:200px;">
                <label for="targetLabel" style="display:block; margin-bottom:4px; font-weight:600; font-size:14px;">
                    To label <span class="aui-icon icon-required">(required)</span>
                </label>
                <input class="text" type="text" id="targetLabel" name="targetLabel"
                       value="$!{targetLabel}" placeholder="e.g. new-label"
                       autocomplete="off" required
                       style="width:100%; box-sizing:border-box;"/>
            </div>
        </div>

        ## ── Scope section ──
        <div style="border:1px solid #dfe1e6; border-radius:3px; padding:16px; margin-bottom:24px;">
            <span style="font-weight:600; font-size:14px; display:block; margin-bottom:12px;">Scope</span>

            ## ── Global spaces ──
            <div style="margin-bottom:16px;">
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:4px;">
                    <span style="font-weight:600; font-size:13px;">Spaces</span>
                    <label style="font-weight:normal; cursor:pointer; font-size:13px; color:#6b778c;">
                        <input type="checkbox" id="allGlobal" value="1"
                               onchange="toggleSelectAll('globalSpaceSelect', this.checked)"
                               style="vertical-align:middle; margin-right:4px;"/>
                        Select all
                    </label>
                </div>
                <select class="multi-select" id="globalSpaceSelect" name="spaceKeys" multiple
                        size="5" style="width:100%; box-sizing:border-box;">
                    #if($globalSpaces)
                    #foreach($sp in $globalSpaces)
                        <option value="$sp.key"
                            #if($action.spaceKeys)
                                #foreach($sk in $action.spaceKeys)
                                    #if($sk == $sp.key) selected #end
                                #end
                            #end
                        >$sp.name ($sp.key)</option>
                    #end
                    #end
                </select>
            </div>

            ## ── Personal spaces ──
            <div>
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:4px;">
                    <span style="font-weight:600; font-size:13px;">Personal spaces</span>
                    <label style="font-weight:normal; cursor:pointer; font-size:13px; color:#6b778c;">
                        <input type="checkbox" id="allPersonal" value="1"
                               onchange="toggleSelectAll('personalSpaceSelect', this.checked)"
                               style="vertical-align:middle; margin-right:4px;"/>
                        Select all
                    </label>
                </div>
                <select class="multi-select" id="personalSpaceSelect" name="spaceKeys" multiple
                        size="5" style="width:100%; box-sizing:border-box;">
                    #if($personalSpaces)
                    #foreach($sp in $personalSpaces)
                        <option value="$sp.key"
                            #if($action.spaceKeys)
                                #foreach($sk in $action.spaceKeys)
                                    #if($sk == $sp.key) selected #end
                                #end
                            #end
                        >$sp.name ($sp.key)</option>
                    #end
                    #end
                </select>
            </div>
        </div>

        <input type="hidden" name="allSpaces" value="false"/>

        ## ── Actions ──
        <div>
            <button class="aui-button aui-button-primary" type="submit">Preview changes</button>
        </div>
    </form>

</div>

<script type="text/javascript">
function toggleSelectAll(selectId, checked) {
    var sel = document.getElementById(selectId);
    for (var i = 0; i < sel.options.length; i++) {
        sel.options[i].selected = checked;
    }
}
</script>

</body>
</html>
