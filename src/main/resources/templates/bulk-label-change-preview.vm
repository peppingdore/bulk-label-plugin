<html>
<head>
    <title>Bulk Label Change – Preview</title>
    <meta name="decorator" content="main"/>
</head>
<body>

<div class="wiki-content" style="max-width:720px; margin:24px auto;">

    <h1>Bulk Label Change – Preview</h1>

    #if($previewResult)

        ## Summary
        <div class="aui-message aui-message-info">
            <p>
                Found <strong>$previewResult.totalCount</strong> item(s) with label
                <span class="aui-lozenge">$!{sourceLabel}</span>.
            </p>
            <p>
                You can edit <strong>$previewResult.editableCount</strong> of them.
                #if($previewResult.skippedCount > 0)
                    <strong>$previewResult.skippedCount</strong> item(s) will be
                    <em>skipped</em> because you don't have edit permission.
                #end
            </p>
        </div>

        #if($previewResult.editableCount > 0)
            <p>
                These items will have their label changed from
                <span class="aui-lozenge">$!{sourceLabel}</span> →
                <span class="aui-lozenge aui-lozenge-success">$!{targetLabel}</span>:
            </p>

            <table class="aui">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Space</th>
                        <th>Title</th>
                    </tr>
                </thead>
                <tbody>
                    #foreach($item in $previewResult.items)
                    <tr>
                        <td>$item.type</td>
                        <td>$!{item.spaceName} <span class="smalltext">($!{item.spaceKey})</span></td>
                        <td><a href="$req.contextPath/pages/viewpage.action?pageId=$item.id">$item.title</a></td>
                    </tr>
                    #end
                </tbody>
            </table>

            <div class="buttons-container" style="margin-top:16px;">
                <div class="buttons">
                    <form class="aui" method="POST" action="execute.action" style="display:inline">
                        #form_xsrfToken()
                        <input type="hidden" name="sourceLabel" value="$!{sourceLabel}"/>
                        <input type="hidden" name="targetLabel" value="$!{targetLabel}"/>
                        <input type="hidden" name="allSpaces" value="$!{action.allSpaces}"/>
                        #if($action.spaceKeys)
                            #foreach($sk in $action.spaceKeys)
                                <input type="hidden" name="spaceKeys" value="$sk"/>
                            #end
                        #end
                        <button class="aui-button aui-button-primary" type="submit"
                                onclick="return confirm('Rename the label on these $previewResult.editableCount item(s)?');">
                            Apply Change
                        </button>
                    </form>
                    <a class="aui-button aui-button-link" href="change.action">Back</a>
                </div>
            </div>
        #else
            <div class="buttons-container" style="margin-top:16px;">
                <a class="aui-button" href="change.action">Back</a>
            </div>
        #end

    #end

</div>

</body>
</html>
